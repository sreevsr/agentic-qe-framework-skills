# =============================================================================
# Environment Variables for Agentic QE Framework
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in the actual values below
# 3. NEVER commit the .env file to Git
# =============================================================================

# --- Web UI Testing ---
TEST_USERNAME=
TEST_PASSWORD=

# --- API Testing ---
API_BASE_URL=
API_TOKEN=
API_USERNAME=
API_PASSWORD=

# --- Application URLs ---
APP_BASE_URL=

# ── Mobile (Appium) ──────────────────────────────────────────────────────────
# Appium server connection
APPIUM_HOST=localhost
APPIUM_PORT=4723

# Android configuration
PLATFORM=android
ANDROID_DEVICE=emulator-5554
# APP_PATH — only set if you want WDIO to install the APK. Leave blank if app is pre-installed.
# Use forward slashes or platform-native paths:
#   Linux:   /home/user/apks/app.apk
#   macOS:   /Users/user/apks/app.apk
#   Windows: C:/Users/user/apks/app.apk  (forward slashes work in Node.js)
APP_PATH=
APP_PACKAGE=com.example.yourapp
APP_ACTIVITY=.MainActivity

# iOS configuration (macOS + Xcode required)
# PLATFORM=ios
# IOS_DEVICE=iPhone 15
# IOS_VERSION=17.0
# IOS_APP_PATH=/Users/user/builds/app.app
# IOS_BUNDLE_ID=com.example.yourapp
# IOS_UDID=                          # required for real devices (xcrun devicectl list devices)

# App state
NO_RESET=false                       # true = preserve app state between runs
