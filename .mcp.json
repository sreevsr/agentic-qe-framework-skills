{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--isolated",
        "--browser", "chromium"
      ]
    },
    "appium": {
      "command": "node",
      "args": ["mcp-servers/appium/dist/index.js"],
      "env": {
        "APPIUM_HOST": "localhost",
        "APPIUM_PORT": "4723",
        "ANDROID_DEVICE": "emulator-5554"
      }
    }
  }
}
